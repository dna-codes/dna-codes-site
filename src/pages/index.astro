---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import DnaHelix from '~/components/DnaHelix.astro';
// import BiggerPicture from '~/components/widgets/BiggerPicture.astro';
import OperationsLayerC from '~/components/widgets/OperationsLayerC.astro';
import LensDemo from '~/components/widgets/LensDemo.astro';
// import ProductLayer from '~/components/widgets/ProductLayer.astro';
// import TechnologyLayer from '~/components/widgets/TechnologyLayer.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
// import { Icon } from 'astro-icon/components';

const metadata = {
  title: 'DNA Codes — Living Operations for Your Team',
  // title: 'DNA Codes — The Source Code for Your Business',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Living operations for your team"
    actions={[
      { variant: 'primary', text: 'Playground', href: '/playground' },
      { text: 'Docs', href: '/docs' },
    ]}
  >
    <DnaHelix
      slot="bg"
      orientation="horizontal"
      helixWidth={120}
      nodeSize={12}
      filled
      style="height:58%;margin-top:5%"
    />

    <Fragment slot="title">
      One model.<br />
      <span class="text-accent">Every view.</span>
      <!-- Finally, process docs that<br />
      <span class="text-accent">keep up with your business.</span> -->
    </Fragment>

    <Fragment slot="subtitle">
      Describe your business once in DNA.<br class="hidden md:block" />
      Operate it through various lenses.
    </Fragment>

    <!-- The demo lives in the hero's image slot so the headline flows straight into it. -->
    <Fragment slot="image">
      <div class="max-w-3xl mx-auto px-4 sm:px-6">
        <LensDemo />
      </div>
    </Fragment>
  </Hero>

  <!-- <BiggerPicture /> -->

  <OperationsLayerC />

  <!-- Arrow connector (ops → product) -->
  <!-- <div class="flex flex-col items-center -mt-8 -mb-8 relative z-10">
    <div class="w-0.5 h-12 bg-gradient-to-b from-primary/60 to-primary"></div>
    <div
      class="w-10 h-10 rounded-full border-2 border-primary bg-primary/10 shadow-[0_0_24px_rgba(13,148,136,0.5)] flex items-center justify-center"
    >
      <Icon name="tabler:arrow-down" class="w-5 h-5 text-primary" />
    </div>
    <div class="w-0.5 h-12 bg-gradient-to-b from-primary to-primary/60"></div>
  </div>

  <ProductLayer /> -->

  <!-- Arrow connector (product → technology) -->
  <!-- <div class="flex flex-col items-center -mt-8 -mb-8 relative z-10">
    <div class="w-0.5 h-12 bg-gradient-to-b from-primary/60 to-primary"></div>
    <div
      class="w-10 h-10 rounded-full border-2 border-primary bg-primary/10 shadow-[0_0_24px_rgba(13,148,136,0.5)] flex items-center justify-center"
    >
      <Icon name="tabler:arrow-down" class="w-5 h-5 text-primary" />
    </div>
    <div class="w-0.5 h-12 bg-gradient-to-b from-primary to-primary/60"></div>
  </div>

  <TechnologyLayer /> -->

  <CallToAction
    actions={[
      { variant: 'primary', text: 'Playground', href: '/playground' },
      { text: 'Docs', href: '/docs' },
    ]}
  >
    <Fragment slot="title">
      Bring order<br class="block sm:hidden" />
      <span class="sm:whitespace-nowrap"> to your ops.</span>
    </Fragment>

    <Fragment slot="subtitle"> Encode your processes. Give your team a single source of truth. </Fragment>
  </CallToAction>
</Layout>

