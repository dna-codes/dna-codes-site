---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import AnimatedDemo from '../components/AnimatedDemo.astro';
import CTA from '../components/CTA.astro';

const features = [
  {
    title: 'A taxonomy that reflects how you actually work',
    description:
      'Model your real org: roles, groups, resources, and the relationships between them. Not a static org chart — a living definition of who does what, to what, and under what rules.',
  },
  {
    title: 'Process flows that never go stale',
    description:
      'Define your operations once in DNA. Process documentation, workflow diagrams, and handoff specs are generated from it — so when the process changes, everything updates together.',
  },
  {
    title: 'Business rules that stay enforced',
    description:
      'Encode constraints directly in the model: approval chains, role cardinalities, access logic, escalation paths. They live in one place instead of scattered across tribal knowledge and stale wikis.',
  },
  {
    title: 'Engineering builds what you actually described',
    description:
      'When product and engineering need to build, they build from your model. No translation layer, no lost-in-handoff errors. The same DNA that defines your operations drives the API specs and system design.',
  },
];
---

<Layout title="DNA Codes — one model for how your business operates">
  <main>
    <Hero
      headline="Your operations, finally in one place"
      subheadline="BizOps leaders spend more time maintaining scattered docs than running the business. Operational DNA gives your org structure, roles, and processes a single authoritative model — and generates everything else from it."
      ctaLabel="See how it works"
      ctaHref="https://app.dna.codes"
    />
    <Features features={features} />
    <AnimatedDemo />
    <CTA
      headline="Stop duct-taping your operations together."
      label="Get started with Operational DNA"
      href="https://app.dna.codes"
    />
  </main>
</Layout>
