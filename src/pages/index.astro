---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import Features from '../components/Features.astro';
import AnimatedDemo from '../components/AnimatedDemo.astro';
import CTA from '../components/CTA.astro';

const features = [
  {
    title: 'A taxonomy that reflects reality',
    description: 'Roles, groups, resources, and relationships — structured, not scattered.',
  },
  {
    title: 'Process flows that never go stale',
    description: 'Change the model once. Every doc and diagram updates with it.',
  },
  {
    title: 'Business rules that stay enforced',
    description: 'Approval chains, access logic, escalation paths — in the model, not buried in wikis.',
  },
  {
    title: 'Engineering builds what you described',
    description: 'Your operational model drives API specs and system design. No translation needed.',
  },
];
---

<Layout title="DNA Codes — operational structure for modern teams">
  <main>
    <Hero
      headline="Your operations, in one model"
      subheadline="Define roles, processes, and business rules once. Generate docs, workflows, and specs automatically."
      ctaLabel="Get started"
      ctaHref="https://app.dna.codes"
    />
    <Features features={features} />
    <AnimatedDemo />
    <CTA
      headline="Put your operations in writing."
      label="Get started"
      href="https://app.dna.codes"
    />
  </main>
</Layout>
