---
import PageLayout from '~/layouts/PageLayout.astro';
import Sidebar from '~/components/docs/Sidebar.astro';
import type { Anchor } from '~/components/docs/Sidebar.astro';

import type { MetaData } from '~/types';

export interface Props {
  metadata?: MetaData;
  title?: string;
  description?: string;
  anchors?: Anchor[];
}

const { metadata, title, description, anchors = [] } = Astro.props;
const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<PageLayout metadata={metadata}>
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 gap-10 lg:grid-cols-[16rem_minmax(0,1fr)]">
      <aside class="hidden lg:block">
        <Sidebar currentPath={currentPath} anchors={anchors} />
      </aside>

      <div class="min-w-0">
        <!-- Mobile docs nav — the sidebar is hidden below lg, so surface it as a disclosure. -->
        <details class="mb-8 rounded-lg border border-gray-200 lg:hidden dark:border-slate-700">
          <summary
            class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold text-gray-900 dark:text-white"
          >
            Docs menu
          </summary>
          <div class="border-t border-gray-200 px-4 py-3 dark:border-slate-700">
            <Sidebar currentPath={currentPath} anchors={anchors} />
          </div>
        </details>

        {
          title && (
            <header class="mb-10 border-b border-gray-200 pb-6 dark:border-slate-700">
              <h1 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl dark:text-white">{title}</h1>
              {description && <p class="mt-3 text-lg text-gray-600 dark:text-slate-400">{description}</p>}
            </header>
          )
        }

        <article class="prose prose-slate max-w-none dark:prose-invert">
          <slot />
        </article>
      </div>
    </div>
  </div>
</PageLayout>
