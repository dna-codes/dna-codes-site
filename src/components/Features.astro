---
interface Feature {
  title: string;
  description: string;
}

interface Props {
  features: Feature[];
}

const { features } = Astro.props;
---

<section class="features">
  <h2 class="section-title">One model. Every operational artifact.</h2>
  <ul class="feature-grid">
    {features.map((f) => (
      <li class="feature-card">
        <h3>{f.title}</h3>
        <p>{f.description}</p>
      </li>
    ))}
  </ul>
</section>

<style>
  .features {
    padding: 5rem 0;
  }

  .section-title {
    font-size: 2rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 3rem;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 1.5rem;
    list-style: none;
  }

  .feature-card {
    background: var(--color-surface);
    border: 1px solid rgba(99, 102, 241, 0.2);
    border-radius: 12px;
    padding: 1.75rem;
  }

  .feature-card h3 {
    font-size: 1.15rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
    color: var(--color-accent-light);
  }

  .feature-card p {
    color: var(--color-muted);
    font-size: 0.95rem;
  }
</style>
