---
import { Icon } from 'astro-icon/components';

const KNOWLEDGE_SOURCES = [
  { name: 'Slack', icon: 'simple-icons:slack' },
  { name: 'Notion', icon: 'simple-icons:notion' },
  { name: 'Confluence', icon: 'simple-icons:confluence' },
  { name: 'Docs', icon: 'simple-icons:googledocs' },
  { name: 'Gmail', icon: 'simple-icons:gmail' },
  { name: 'Zoom', icon: 'simple-icons:zoom' },
];
---

<section id="playground" class="py-12 sm:py-16">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1
        class="inline-flex items-center px-5 py-2 rounded-full border-2 border-primary bg-primary/10 text-sm font-semibold text-primary uppercase tracking-[0.2em] mb-4"
      >
        Playground
      </h1>
      <h2 class="text-3xl sm:text-4xl font-bold text-slate-100 mb-3">
        Knowledge in.<br class="sm:hidden" />
        <span class="text-accent"> Operating model out.</span>
      </h2>
      <p class="text-slate-400 max-w-2xl mx-auto text-sm sm:text-base leading-relaxed">
        DNA Codes compiles meeting notes and docs into a living spec and generates the runbooks, SOPs, and agents your
        team runs on.
      </p>
    </div>

    <!-- Layout: stacked on mobile, two-column on md+ -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4 sm:gap-6">
      <!-- Left column: Input + DNA -->
      <div class="flex flex-col gap-4 sm:gap-6 min-w-0">
        <!-- Input region -->
        <div class="bg-slate-900/80 rounded-2xl border border-white/10 p-4 sm:p-5">
          <div class="flex items-center justify-between gap-2 mb-3">
            <div class="flex items-center gap-2 min-w-0">
              <div
                class="w-7 h-7 rounded-lg bg-primary/20 border border-primary/40 flex items-center justify-center flex-shrink-0"
              >
                <span class="text-xs font-black text-primary font-mono">01</span>
              </div>
              <span class="text-xs font-bold uppercase tracking-widest text-primary">Input</span>
            </div>
            <div class="flex items-center gap-2">
              <label for="pg-example" class="sr-only">Load an example</label>
              <select
                id="pg-example"
                class="text-xs font-semibold text-slate-200 bg-slate-800/80 border border-slate-600 rounded-lg px-2.5 py-1.5 focus:outline-none focus:border-primary focus:ring-1 focus:ring-primary hover:border-slate-500 cursor-pointer"
              >
                <option value="" selected disabled>Load an example…</option>
                <option value="onboarding">Customer Onboarding</option>
                <option value="launch">Product Launch</option>
                <option value="close">Monthly Close</option>
              </select>
            </div>
          </div>

          <label for="transcript-input" class="sr-only">Example transcript</label>
          <textarea
            id="transcript-input"
            readonly
            aria-readonly="true"
            class="w-full min-h-[12rem] px-3 py-3 rounded-lg bg-slate-800/50 border border-slate-700 text-slate-300 placeholder-slate-500 text-sm focus:outline-none resize-y cursor-default"
            placeholder="Pick an example above to load a transcript and watch it become DNA. Pasting your own transcript is coming soon."
          ></textarea>

          <div class="mt-3">
            <p class="text-[10px] font-semibold uppercase tracking-widest text-slate-500 mb-2">Works with</p>
            <div class="flex flex-wrap gap-1.5">
              {
                KNOWLEDGE_SOURCES.map(({ name, icon }) => (
                  <span class="inline-flex items-center gap-1.5 bg-slate-800/60 border border-white/10 rounded-lg px-2.5 py-1.5">
                    <Icon name={icon} class="w-3.5 h-3.5 text-slate-400 flex-shrink-0" />
                    <span class="text-xs text-slate-400">{name}</span>
                  </span>
                ))
              }
            </div>
          </div>
        </div>

        <!-- DNA region -->
        <div
          class="bg-slate-900/90 rounded-2xl border border-primary/60 shadow-[0_0_40px_rgba(13,148,136,0.2)] overflow-hidden"
        >
          <div class="flex items-center gap-2 px-4 sm:px-5 pt-4 pb-3 border-b border-white/8">
            <div
              class="w-7 h-7 rounded-lg bg-primary/25 border border-primary/40 flex items-center justify-center flex-shrink-0"
            >
              <Icon name="tabler:dna" class="w-4 h-4 text-primary" />
            </div>
            <span class="text-xs font-bold text-primary uppercase tracking-widest">DNA Spec</span>
            <span class="ml-auto text-xs text-slate-400 font-mono truncate">operations.dna</span>
          </div>

          <div id="pg-dna-panel" class="p-4 sm:p-6 min-h-[12rem] overflow-x-auto">
            <div data-state="empty" class="text-sm text-slate-500 italic">
              Your generated DNA spec will appear here after you convert a transcript.
            </div>
            <div data-state="loading" class="hidden flex items-center gap-2 text-sm text-slate-400">
              <span class="pg-spinner"></span>
              Generating DNA spec…
            </div>
            <div data-state="error" class="hidden">
              <p class="text-sm text-rose-300 mb-3"></p>
              <button
                type="button"
                data-retry="dna"
                class="text-xs font-semibold text-slate-200 bg-white/5 hover:bg-white/10 border border-white/10 rounded-md px-3 py-1.5"
              >
                Retry
              </button>
            </div>
            <pre
              data-state="ready"
              class="hidden font-mono text-sm leading-relaxed text-slate-300 whitespace-pre-wrap break-words">
            </pre>
          </div>
        </div>
      </div>

      <!-- Right column: Outputs -->
      <div class="min-w-0">
        <div class="bg-slate-900/90 rounded-2xl border border-white/10 overflow-hidden h-full flex flex-col">
          <div class="px-4 sm:px-5 pt-4 pb-3 border-b border-white/8">
            <div class="flex items-center justify-between gap-2 mb-3 flex-wrap">
              <div class="flex items-center gap-2">
                <div
                  class="w-7 h-7 rounded-lg bg-primary/20 border border-primary/40 flex items-center justify-center flex-shrink-0"
                >
                  <span class="text-xs font-black text-primary font-mono">03</span>
                </div>
                <span class="text-xs font-bold uppercase tracking-widest text-primary">Outputs</span>
              </div>
              <!-- demo-mode badge (remove when live API lands) -->
              <span
                data-pg-demo-badge
                class="inline-flex items-center gap-1.5 text-[10px] font-bold uppercase tracking-widest text-amber-300 bg-amber-500/15 border border-amber-500/30 rounded-full px-2.5 py-1"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>
                Demo mode — sample data
              </span>
            </div>

            <!-- Tab strip: horizontally scrollable on narrow viewports -->
            <div class="-mx-1 overflow-x-auto">
              <div class="flex gap-1 px-1 min-w-max">
                <button
                  data-out="process-flow"
                  class="pg-tab active-tab px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors duration-150"
                >
                  Process Flow
                </button>
                <!-- RACI disabled — not used widely; re-enable by uncommenting this tab, the
                     matching panel below, and 'raci' in the client script's OUTPUT_TYPES array.
                <button
                  data-out="raci"
                  class="pg-tab px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors duration-150"
                >
                  RACI
                </button>
                -->
                <button
                  data-out="sop"
                  class="pg-tab px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors duration-150"
                >
                  SOP
                </button>
                <!-- Runbook disabled — SOP kept instead; re-enable the same way as RACI above.
                <button
                  data-out="runbook"
                  class="pg-tab px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors duration-150"
                >
                  Runbook
                </button>
                -->
                <button
                  data-out="agents"
                  class="pg-tab px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors duration-150"
                >
                  Agents
                </button>
                <button
                  data-out="app"
                  class="pg-tab px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors duration-150"
                >
                  App
                </button>
              </div>
            </div>
          </div>

          <div class="p-4 sm:p-5 flex-1">
            {
              [
                'process-flow',
                // 'raci', // disabled — not used widely
                'sop',
                // 'runbook', // disabled — SOP kept instead
                'agents',
                'app',
              ].map((t, i) => (
                <div id={`out-${t}`} class:list={['pg-out', i === 0 ? '' : 'hidden']}>
                  <div data-state="empty" class="text-sm text-slate-500 italic min-h-[12rem] flex items-center">
                    Run a conversion to see this artifact.
                  </div>
                  <div data-state="loading" class="hidden flex items-center gap-2 text-sm text-slate-400 min-h-[12rem]">
                    <span class="pg-spinner" />
                    Generating…
                  </div>
                  <div data-state="error" class="hidden min-h-[12rem]">
                    <p class="text-sm text-rose-300 mb-3" />
                    <button
                      type="button"
                      data-retry={t}
                      class="text-xs font-semibold text-slate-200 bg-white/5 hover:bg-white/10 border border-white/10 rounded-md px-3 py-1.5"
                    >
                      Retry
                    </button>
                  </div>
                  <div data-state="ready" class="hidden" />
                </div>
              ))
            }
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  :global(#playground ::-webkit-scrollbar) {
    width: 8px;
    height: 8px;
  }
  :global(#playground ::-webkit-scrollbar-track) {
    background: rgb(15 22 40);
  }
  :global(#playground ::-webkit-scrollbar-thumb) {
    background: rgb(13 148 136);
    border-radius: 4px;
  }
  :global(#playground ::-webkit-scrollbar-thumb:hover) {
    background: rgb(45 212 191);
  }
  :global(#playground *) {
    scrollbar-width: thin;
    scrollbar-color: rgb(13 148 136) rgb(15 22 40);
  }

  .pg-tab {
    color: rgb(100 116 139);
    cursor: pointer;
    border: 1px solid transparent;
    background: transparent;
  }
  .pg-tab:hover {
    color: rgb(203 213 225);
    background: rgb(255 255 255 / 0.07);
    border-color: rgb(255 255 255 / 0.1);
  }
  .pg-tab.active-tab {
    background: rgb(13 148 136 / 0.2);
    color: rgb(45 212 191);
    border-color: rgb(13 148 136 / 0.4);
  }
  .pg-spinner {
    display: inline-block;
    width: 14px;
    height: 14px;
    border: 2px solid rgb(148 163 184 / 0.3);
    border-top-color: rgb(45 212 191);
    border-radius: 9999px;
    animation: pg-spin 0.8s linear infinite;
  }
  @keyframes pg-spin {
    to {
      transform: rotate(360deg);
    }
  }
</style>

<script>
  import { convert, ConvertError } from '~/utils/dnaApi';
  import type { ConvertResult, ToType } from '~/utils/dnaApi';

  // Pre-baked example transcripts. Each is worded so the stub routes it to a
  // distinct process (see pickProcess in dnaApi). Keyed to the dropdown values.
  const EXAMPLES: Record<string, string> = {
    onboarding: `Customer onboarding kickoff — 2026-05-15

Attendees: Priya (CS lead), Marco (Sales), Devon (Ops)

Priya: When a new customer signs up, the trigger is "new-signup". CS owns the whole flow. First touch is an automated welcome email that goes out immediately.

Marco: Sales hands off the account, then we want an intro call booked inside 24 hours. Devon and I agree — that's the SLA we want to commit to.

Devon: After the intro call, we walk them through the product on day 3, then we do a structured 30-day check-in to make sure they're seeing value. The 30-day check-in is the moment we know if onboarding succeeded.

Priya: Plan upgrades also trigger this flow — anyone who moves from free to paid gets the same treatment.

Action items: document the flow, set the 24h SLA, and make sure the 30-day check-in is on the calendar by day 28.`,
    launch: `Product launch planning — 2026-05-20

Attendees: Ana (Product), Ben (Engineering), Carla (Sales)

Ana: A launch kicks off when the roadmap is approved. Product owns go-to-market. First we run market validation, then engineering builds for several weeks.

Ben: After the build, Sales runs GTM prep the week before launch day.

Carla: Launch day is cross-functional — Product, Engineering, and Sales all in. Two weeks later Product runs a post-launch review.

Ana: Exec sign-off is required before we commit, and we hold ourselves to a 90-day cycle end to end.`,
    close: `Monthly close review — 2026-05-28

Attendees: Dana (Finance), Eli (Operations), Farah (Leadership)

Dana: The monthly close triggers at month-end. Finance owns it. We close the books on day one, then reconcile accounts on day two.

Eli: Operations reviews variance on day three.

Dana: Finance produces the exec report on day four, and Leadership signs off on the board package on day five.

Farah: The SLA is a 5-day close, and the same flow runs at quarter-end.`,
  };

  type ArtifactType = Exclude<ToType, 'dna'>;
  // 'raci' and 'runbook' are disabled (see the tab strip and panel list above) but
  // stay valid ArtifactType members so re-enabling them is a one-line change here.
  const ARTIFACTS: ArtifactType[] = ['process-flow', 'sop', 'agents', 'app'];

  const $ = <T extends Element = Element>(sel: string, root: ParentNode = document) =>
    root.querySelector(sel) as T | null;
  const $$ = <T extends Element = Element>(sel: string, root: ParentNode = document) =>
    Array.from(root.querySelectorAll(sel)) as T[];

  const textarea = $<HTMLTextAreaElement>('#transcript-input');
  const exampleSelect = $<HTMLSelectElement>('#pg-example');
  const dnaPanel = $<HTMLElement>('#pg-dna-panel');

  if (!textarea || !exampleSelect || !dnaPanel) {
    // Defensive — markup above guarantees these exist; if not, do nothing.
  } else {
    let currentDna = '';
    const inFlight: Partial<Record<'dna' | ArtifactType, AbortController>> = {};

    const setPanelState = (panel: HTMLElement, state: 'empty' | 'loading' | 'error' | 'ready') => {
      $$('[data-state]', panel).forEach((el) => {
        const el2 = el as HTMLElement;
        if (el2.dataset.state === state) {
          el2.style.removeProperty('display');
          el2.classList.remove('hidden');
        } else {
          // Use inline display:none so class-level conflicts (e.g. `flex` on the
          // same element) can't accidentally win over `hidden`.
          el2.style.display = 'none';
        }
      });
    };

    const setPanelError = (panel: HTMLElement, message: string) => {
      const errEl = panel.querySelector('[data-state="error"]') as HTMLElement | null;
      if (errEl) {
        const p = errEl.querySelector('p');
        if (p) p.textContent = message;
      }
      setPanelState(panel, 'error');
    };

    const userMessage = (err: unknown): string => {
      if (err instanceof ConvertError) return err.userMessage;
      return 'Something went wrong. Give it another try.';
    };

    const getArtifactPanel = (type: ArtifactType) => $<HTMLElement>(`#out-${type}`);

    // ── Renderers ────────────────────────────────────────────────────────

    const escapeHtml = (s: string) =>
      s.replace(
        /[&<>"']/g,
        (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c] as string
      );

    const renderDna = (content: string): string => {
      // Lightweight YAML-ish syntax coloring matching OperationsLayerC.astro
      const lines = content.split('\n').map((rawLine) => {
        const line = escapeHtml(rawLine);
        // key: value pattern
        const m = line.match(/^(\s*)(-?\s*)([A-Za-z][\w-]*)(:)(.*)$/);
        if (m) {
          const [, indent, dash, key, colon, rest] = m;
          return `${indent}<span class="text-slate-500">${dash}</span><span class="text-violet-400">${key}</span><span class="text-slate-500">${colon}</span><span class="text-amber-300">${rest}</span>`;
        }
        // list item: "- value"
        const li = line.match(/^(\s*)(-)(\s+)(.*)$/);
        if (li) {
          const [, indent, dash, sp, val] = li;
          return `${indent}<span class="text-slate-500">${dash}</span>${sp}<span class="text-violet-400">${val}</span>`;
        }
        return line;
      });
      return lines.join('\n');
    };

    const renderProcessFlow = (r: Extract<ConvertResult, { type: 'process-flow' }>): string => {
      const steps = r.steps ?? [];
      const rows = steps.map((s, i) => {
        const isLast = i === steps.length - 1;
        const owner = s.owner
          ? `<span class="rounded bg-white/8 px-1.5 py-0.5 text-xs text-slate-400">${escapeHtml(s.owner)}</span>`
          : '';
        const timing = s.timing ? `<span class="text-xs text-slate-500">${escapeHtml(s.timing)}</span>` : '';
        const connector = isLast ? '' : '<div class="w-px flex-1 min-h-[16px] bg-white/10 my-0.5"></div>';
        return `
          <div class="flex gap-2.5">
            <div class="flex flex-col items-center flex-shrink-0">
              <div class="w-5 h-5 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center">
                <span class="text-[10px] font-bold text-primary">${i + 1}</span>
              </div>
              ${connector}
            </div>
            <div class="pb-3">
              <p class="text-sm text-slate-200 leading-tight">${escapeHtml(s.name ?? '')}</p>
              <div class="mt-1 flex items-center gap-2 flex-wrap">${owner}${timing}</div>
            </div>
          </div>`;
      });
      return `
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <span class="text-xs font-bold uppercase tracking-widest text-violet-300 bg-violet-500/20 border border-violet-500/30 rounded-full px-2.5 py-1">
            Process Flow
          </span>
          <span class="text-xs text-slate-500 font-mono">${escapeHtml(r.process ?? '')}</span>
        </div>
        <div>${rows.join('')}</div>`;
    };

    const renderRaci = (r: Extract<ConvertResult, { type: 'raci' }>): string => {
      const roles = r.roles ?? [];
      const rows = r.rows ?? [];
      const cellClass = (c: string) => {
        switch (c) {
          case 'R':
            return 'bg-primary/25 text-primary';
          case 'A':
            return 'bg-amber-500/25 text-amber-300';
          case 'C':
            return 'bg-violet-500/25 text-violet-300';
          case 'I':
            return 'bg-white/5 text-slate-500';
          default:
            return 'bg-transparent text-slate-700';
        }
      };
      const head = roles
        .map(
          (role) => `<th class="text-center text-[10px] text-slate-500 font-medium pb-2 px-1">${escapeHtml(role)}</th>`
        )
        .join('');
      const body = rows
        .map(
          (row) => `
        <tr>
          <td class="text-slate-300 py-1.5 pr-3 text-xs">${escapeHtml(row.process ?? '')}</td>
          ${(row.cells ?? [])
            .map(
              (c) => `
            <td class="text-center py-1.5 px-1">
              <span class="inline-block w-5 h-5 rounded text-[10px] font-bold leading-5 text-center ${cellClass(c)}">${escapeHtml(c ?? '')}</span>
            </td>`
            )
            .join('')}
        </tr>`
        )
        .join('');
      const legend = [
        ['R', 'bg-primary/25 text-primary', 'Responsible'],
        ['A', 'bg-amber-500/25 text-amber-300', 'Accountable'],
        ['C', 'bg-violet-500/25 text-violet-300', 'Consulted'],
        ['I', 'bg-white/5 text-slate-500', 'Informed'],
      ]
        .map(
          ([letter, cls, label]) => `
        <div class="flex items-center gap-1">
          <span class="inline-block w-4 h-4 rounded text-[9px] font-bold leading-4 text-center ${cls}">${letter}</span>
          <span class="text-[10px] text-slate-500">${label}</span>
        </div>`
        )
        .join('');
      return `
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <span class="text-xs font-bold uppercase tracking-widest text-emerald-300 bg-emerald-500/20 border border-emerald-500/30 rounded-full px-2.5 py-1">
            RACI Matrix
          </span>
          <span class="text-xs text-slate-500 font-mono">auto-generated</span>
        </div>
        <div class="overflow-x-auto">
          <table class="w-full text-xs border-collapse">
            <thead>
              <tr>
                <th class="text-left text-[10px] text-slate-500 font-medium pb-2 pr-3 w-1/2">Process</th>
                ${head}
              </tr>
            </thead>
            <tbody class="divide-y divide-white/5">${body}</tbody>
          </table>
          <div class="mt-3 flex items-center gap-3 flex-wrap">${legend}</div>
        </div>`;
    };

    const renderSop = (r: Extract<ConvertResult, { type: 'sop' }>): string => {
      const steps = (r.steps ?? [])
        .map((s, i) => `<div class="text-sm text-slate-300">${i + 1}. ${escapeHtml(s)}</div>`)
        .join('');
      const ownerBlock = r.owner
        ? `<div>
            <div class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Owner</div>
            <div class="text-sm text-sky-400 font-mono">${escapeHtml(r.owner)}</div>
          </div>`
        : '';
      const slaBlock = r.sla
        ? `<div>
            <div class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">SLA</div>
            <div class="text-sm text-emerald-400">${escapeHtml(r.sla)}</div>
          </div>`
        : '';
      return `
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <span class="text-xs font-bold uppercase tracking-widest text-sky-300 bg-sky-500/20 border border-sky-500/30 rounded-full px-2.5 py-1">
            SOP Document
          </span>
          <div class="inline-flex items-center gap-1.5 bg-slate-700/60 border border-white/10 rounded px-2 py-1">
            <span class="text-xs text-slate-400">PDF</span>
          </div>
        </div>
        <div class="space-y-3">
          <div>
            <div class="text-sm font-semibold text-slate-200 mb-1.5">${escapeHtml(r.title ?? 'Standard Operating Procedure')}</div>
          </div>
          ${ownerBlock}
          <div>
            <div class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Steps</div>
            <div class="space-y-1">${steps}</div>
          </div>
          ${slaBlock}
        </div>`;
    };

    const renderRunbook = (r: Extract<ConvertResult, { type: 'runbook' }>): string => {
      const groups = (r.groups ?? [])
        .map(
          ({ area, processes }) => `
        <div>
          <div class="flex items-center gap-2 mb-1">
            <span class="text-xs font-semibold text-slate-200">${escapeHtml(area ?? '')}</span>
            <span class="text-[10px] text-slate-500 bg-white/5 rounded px-1.5 py-0.5">${(processes ?? []).length} processes</span>
          </div>
          <div class="ml-3 space-y-0.5">
            ${(processes ?? [])
              .map(
                (p) => `
              <div class="flex items-center gap-1.5">
                <div class="w-1 h-1 rounded-full bg-slate-600 flex-shrink-0"></div>
                <span class="text-xs text-slate-400">${escapeHtml(p)}</span>
              </div>`
              )
              .join('')}
          </div>
        </div>`
        )
        .join('');
      return `
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <span class="text-xs font-bold uppercase tracking-widest text-amber-300 bg-amber-500/20 border border-amber-500/30 rounded-full px-2.5 py-1">
            Runbook
          </span>
          <span class="text-xs text-slate-500 font-mono">ops-runbook.dna</span>
        </div>
        <div class="space-y-2">${groups}</div>`;
    };

    const renderAgentWorkflow = (r: Extract<ConvertResult, { type: 'agents' }>): string => {
      const steps = r.steps ?? [];
      const rows = steps.map((s, i) => {
        const isLast = i === steps.length - 1;
        const isAgent = s.actor === 'agent';
        const actorBadge = isAgent
          ? `<span class="rounded-full bg-cyan-500/20 border border-cyan-500/30 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-cyan-300">Agent</span>`
          : `<span class="rounded-full bg-white/8 border border-white/10 px-1.5 py-0.5 text-[10px] font-bold uppercase tracking-wide text-slate-400">Human</span>`;
        const owner = s.owner
          ? `<span class="rounded bg-white/8 px-1.5 py-0.5 text-xs text-slate-400">${escapeHtml(s.owner)}</span>`
          : '';
        const timing = s.timing ? `<span class="text-xs text-slate-500">${escapeHtml(s.timing)}</span>` : '';
        const connector = isLast
          ? ''
          : `<div class="w-px flex-1 min-h-[16px] ${isAgent ? 'bg-cyan-500/30' : 'bg-white/10'} my-0.5"></div>`;
        return `
          <div class="flex gap-2.5">
            <div class="flex flex-col items-center flex-shrink-0">
              <div class="w-5 h-5 rounded-full border flex items-center justify-center ${isAgent ? 'bg-cyan-500/20 border-cyan-500/40' : 'bg-white/10 border-white/20'}">
                <span class="text-[10px] font-bold ${isAgent ? 'text-cyan-300' : 'text-slate-300'}">${i + 1}</span>
              </div>
              ${connector}
            </div>
            <div class="pb-3">
              <div class="flex items-center gap-1.5 flex-wrap">
                <p class="text-sm text-slate-200 leading-tight">${escapeHtml(s.name ?? '')}</p>
                ${actorBadge}
              </div>
              <div class="mt-1 flex items-center gap-2 flex-wrap">${owner}${timing}</div>
            </div>
          </div>`;
      });
      return `
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <span class="text-xs font-bold uppercase tracking-widest text-cyan-300 bg-cyan-500/20 border border-cyan-500/30 rounded-full px-2.5 py-1">
            Agent Workflow
          </span>
          <span class="text-xs text-slate-500 font-mono">${escapeHtml(r.process ?? '')}</span>
        </div>
        <div>${rows.join('')}</div>`;
    };

    const renderApp = (r: Extract<ConvertResult, { type: 'app' }>): string => {
      const badge = `
        <div class="flex items-center justify-between mb-4 flex-wrap gap-2">
          <span class="text-xs font-bold uppercase tracking-widest text-orange-300 bg-orange-500/20 border border-orange-500/30 rounded-full px-2.5 py-1">
            Application
          </span>
          <span class="text-xs text-slate-500 font-mono">generated UI</span>
        </div>`;

      if (r.kind === 'none') {
        return `${badge}
          <div class="min-h-[10rem] flex items-center justify-center text-center py-8">
            <p class="text-sm text-slate-500 italic">${escapeHtml(r.emptyMessage ?? 'No application generated for this process.')}</p>
          </div>`;
      }

      if (r.kind === 'stepper') {
        const steps = r.steps ?? [];
        const active = steps[0];
        const nav = steps
          .map(
            (_, i) => `
          <div class="flex items-center ${i === 0 ? '' : 'flex-1'}">
            ${i > 0 ? '<div class="h-px flex-1 bg-white/10"></div>' : ''}
            <div class="w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold flex-shrink-0 ${i === 0 ? 'bg-primary text-slate-950' : 'bg-white/10 text-slate-400 border border-white/15'}">${i + 1}</div>
          </div>`
          )
          .join('');
        const fields = (active?.fields ?? [])
          .map(
            (f) => `
          <div>
            <label class="block text-[10px] font-semibold uppercase tracking-wide text-slate-500 mb-1">${escapeHtml(f)}</label>
            <div class="h-8 rounded-lg bg-slate-800/60 border border-slate-700"></div>
          </div>`
          )
          .join('');
        return `${badge}
          <div class="rounded-xl border border-white/10 bg-slate-950/40 p-4">
            <div class="text-sm font-semibold text-slate-200 mb-3">${escapeHtml(r.title ?? '')}</div>
            <div class="flex items-center mb-4">${nav}</div>
            <div class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-2">${escapeHtml(active?.name ?? '')}</div>
            <div class="space-y-3">${fields}</div>
            <div class="mt-4 flex justify-end gap-2">
              <button type="button" disabled class="text-xs font-semibold text-slate-500 bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 cursor-not-allowed">Back</button>
              <button type="button" disabled class="btn-primary text-xs font-semibold rounded-lg px-3 py-1.5 opacity-50 cursor-not-allowed">Continue</button>
            </div>
          </div>
          <p class="mt-2 text-[11px] text-slate-500">Step 1 of ${steps.length}</p>`;
      }

      // kind === 'review'
      const items = (r.reviewItems ?? [])
        .map(
          (it) => `
        <div class="flex items-center justify-between gap-2 py-2 border-b border-white/5 last:border-0">
          <span class="text-sm text-slate-300">${escapeHtml(it.label)}</span>
          <span class="text-sm font-mono ${it.flagged ? 'text-amber-300' : 'text-slate-400'} flex items-center gap-1.5">
            ${it.flagged ? '<span class="w-1.5 h-1.5 rounded-full bg-amber-400"></span>' : ''}${escapeHtml(it.value)}
          </span>
        </div>`
        )
        .join('');
      return `${badge}
        <div class="rounded-xl border border-white/10 bg-slate-950/40 p-4">
          <div class="text-sm font-semibold text-slate-200 mb-1">${escapeHtml(r.title ?? '')}</div>
          <p class="text-xs text-slate-500 mb-3">Flagged rows exceed variance threshold.</p>
          <div>${items}</div>
          <div class="mt-4 flex justify-end gap-2">
            <button type="button" disabled class="text-xs font-semibold text-slate-500 bg-white/5 border border-white/10 rounded-lg px-3 py-1.5 cursor-not-allowed">Escalate</button>
            <button type="button" disabled class="btn-primary text-xs font-semibold rounded-lg px-3 py-1.5 opacity-50 cursor-not-allowed">Approve</button>
          </div>
        </div>`;
    };

    const renderArtifact = (type: ArtifactType, result: ConvertResult) => {
      const panel = getArtifactPanel(type);
      if (!panel) return;
      const ready = panel.querySelector('[data-state="ready"]') as HTMLElement | null;
      if (!ready) return;
      let html = '';
      if (type === 'process-flow' && result.type === 'process-flow') html = renderProcessFlow(result);
      else if (type === 'raci' && result.type === 'raci') html = renderRaci(result);
      else if (type === 'sop' && result.type === 'sop') html = renderSop(result);
      else if (type === 'runbook' && result.type === 'runbook') html = renderRunbook(result);
      else if (type === 'agents' && result.type === 'agents') html = renderAgentWorkflow(result);
      else if (type === 'app' && result.type === 'app') html = renderApp(result);
      ready.innerHTML = html;
      setPanelState(panel, 'ready');
    };

    // ── Flow ─────────────────────────────────────────────────────────────

    const runArtifact = async (type: ArtifactType, dna: string) => {
      const panel = getArtifactPanel(type);
      if (!panel) return;
      inFlight[type]?.abort();
      setPanelState(panel, 'loading');
      try {
        const result = await convert({ from: { type: 'dna', content: dna }, to: { type } });
        renderArtifact(type, result);
      } catch (err) {
        console.error('[playground] artifact failed', type, err);
        setPanelError(panel, userMessage(err));
      }
    };

    const runDna = async (transcript: string) => {
      setPanelState(dnaPanel, 'loading');
      try {
        const result = await convert({
          from: { type: 'transcript', content: transcript },
          to: { type: 'dna' },
        });
        if (result.type !== 'dna') throw new ConvertError('Unexpected response.');
        currentDna = result.content;
        const ready = dnaPanel.querySelector('[data-state="ready"]') as HTMLElement | null;
        if (ready) ready.innerHTML = renderDna(currentDna);
        setPanelState(dnaPanel, 'ready');
        // Fan out artifact calls in parallel — each manages its own state.
        ARTIFACTS.forEach((t) => {
          void runArtifact(t, currentDna);
        });
      } catch (err) {
        console.error('[playground] dna failed', err);
        setPanelError(dnaPanel, userMessage(err));
        // Reset artifact panels to empty since we have no DNA to fan out from.
        ARTIFACTS.forEach((t) => {
          const p = getArtifactPanel(t);
          if (p) setPanelState(p, 'empty');
        });
      }
    };

    // ── Wiring ───────────────────────────────────────────────────────────

    // Normalize initial visibility (avoids any class-conflict flash before the first
    // user action). Each panel starts in its empty state.
    setPanelState(dnaPanel, 'empty');
    ARTIFACTS.forEach((t) => {
      const p = getArtifactPanel(t);
      if (p) setPanelState(p, 'empty');
    });

    exampleSelect.addEventListener('change', () => {
      const transcript = EXAMPLES[exampleSelect.value];
      if (!transcript) return;
      textarea.value = transcript;
      void runDna(transcript);
    });

    $$('.pg-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const out = (tab as HTMLElement).dataset.out;
        $$('.pg-tab').forEach((t) => t.classList.remove('active-tab'));
        tab.classList.add('active-tab');
        $$('.pg-out').forEach((p) => p.classList.add('hidden'));
        document.getElementById(`out-${out}`)?.classList.remove('hidden');
      });
    });

    // Retry buttons (DNA and each artifact)
    $$('[data-retry]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const target = (btn as HTMLElement).dataset.retry;
        if (target === 'dna') {
          const value = textarea.value.trim();
          if (value) void runDna(value);
          return;
        }
        if (currentDna && ARTIFACTS.includes(target as ArtifactType)) {
          void runArtifact(target as ArtifactType, currentDna);
        }
      });
    });
  }
</script>
