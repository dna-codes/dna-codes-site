---
import { Icon } from 'astro-icon/components';

const steps = [
  {
    number: '1',
    icon: 'tabler:download',
    title: 'Ingest',
    description: 'Bring in documents from all your sources and formats.',
  },
  {
    number: '2',
    icon: 'tabler:sparkles',
    title: 'Structure',
    description: 'Our AI analyzes and organizes information into a structured DNA spec.',
  },
  {
    number: '3',
    icon: 'tabler:list-check',
    title: 'Review',
    description: 'Review, refine, and add context with your team.',
  },
  {
    number: '4',
    icon: 'tabler:refresh',
    title: 'Sync',
    description: 'Output in your preferred format and sync to third party apps.',
  },
];

const outputFormats = ['Markdown', 'PDF', 'JSON', 'HTML', 'And more'];

const integrations = [
  { name: 'Notion', icon: 'ri:notion-fill' },
  { name: 'Confluence', icon: 'logos:confluence' },
  { name: 'Slack', icon: 'devicon:slack' },
  { name: 'Linear', icon: 'simple-icons:linear' },
  { name: 'Airtable', icon: 'logos:airtable' },
  { name: 'SharePoint', icon: 'mdi:microsoft-sharepoint' },
];
---

<section id="how-it-works" class="py-20 scroll-mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="text-center mb-14 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <p class="text-xs font-semibold text-primary uppercase tracking-[0.2em] mb-3">How it works</p>
      <h2 class="text-3xl md:text-4xl font-bold text-slate-100">
        From messy docs to structured clarity in four steps
      </h2>
    </div>

    <!-- Steps row -->
    <div class="relative grid grid-cols-2 md:grid-cols-4 gap-6 mb-14">
      <!-- Dotted connector line (desktop only) -->
      <div
        class="hidden md:block absolute top-8 left-[calc(12.5%+2.5rem)] right-[calc(12.5%+2.5rem)] h-px border-t border-dashed border-white/20"
        aria-hidden="true"
      />

      {
        steps.map(({ number, icon, title, description }) => (
          <div class="group flex flex-col items-center text-center intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade relative cursor-default">
            <div class="relative mb-4">
              <div class="w-16 h-16 rounded-2xl bg-primary/10 border border-primary/25 flex items-center justify-center transition-all ease-in duration-200 group-hover:bg-primary/20 group-hover:border-primary/50 group-hover:shadow-lg group-hover:shadow-primary/15 group-hover:-translate-y-1">
                <Icon name={icon} class="w-7 h-7 text-primary transition-transform ease-in duration-200 group-hover:scale-110" />
              </div>
              <span class="absolute -top-2 -left-2 w-5 h-5 rounded-full bg-primary text-[10px] font-bold text-white flex items-center justify-center">
                {number}
              </span>
            </div>
            <h3 class="font-semibold text-slate-100 mb-1 transition-colors ease-in duration-200 group-hover:text-primary">{title}</h3>
            <p class="text-sm text-slate-500">{description}</p>
          </div>
        ))
      }
    </div>

    <!-- Output + Integrations panels -->
    <div class="grid md:grid-cols-2 gap-4 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <!-- Output formats -->
      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition-colors ease-in duration-200 hover:bg-white/[0.05] hover:border-white/20">
        <h3 class="font-semibold text-slate-200 mb-1">Output in your format</h3>
        <p class="text-sm text-slate-500 mb-5">Export your DNA spec however your team works.</p>
        <div class="flex flex-wrap gap-2">
          {
            outputFormats.map((fmt, i) => (
              <span
                class:list={[
                  'px-3 py-1.5 rounded-lg text-sm font-medium border transition-all ease-in duration-200',
                  i < outputFormats.length - 1
                    ? 'border-white/15 bg-white/5 text-slate-300 hover:bg-primary/10 hover:border-primary/30 hover:text-slate-100'
                    : 'border-dashed border-white/10 text-slate-500',
                ]}
              >
                {fmt}
              </span>
            ))
          }
        </div>
      </div>

      <!-- Integrations -->
      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-6 transition-colors ease-in duration-200 hover:bg-white/[0.05] hover:border-white/20">
        <h3 class="font-semibold text-slate-200 mb-1">Sync to the tools you use</h3>
        <p class="text-sm text-slate-500 mb-5">Keep your DNA spec connected across your stack.</p>
        <div class="flex flex-wrap gap-3">
          {
            integrations.map(({ name, icon }) => (
              <div
                class="w-10 h-10 rounded-xl bg-white/5 border border-white/10 flex items-center justify-center transition-all ease-in duration-200 hover:bg-primary/10 hover:border-primary/30 hover:scale-110 hover:-translate-y-0.5"
                title={name}
              >
                <Icon name={icon} class="w-5 h-5 text-slate-400 transition-colors ease-in duration-200 group-hover:text-primary" />
              </div>
            ))
          }
          <div class="w-10 h-10 rounded-xl bg-white/5 border border-dashed border-white/10 flex items-center justify-center text-slate-500 text-sm font-medium transition-all ease-in duration-200 hover:border-white/20 hover:text-slate-400">
            +
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
