---
// Homepage lens demo — one sample operational DNA, shown through three simple
// views: an org chart, a process flow, and a runbook. The visual payoff of the
// "one model, many views" thesis. Client-side only, no backend.
import { Icon } from 'astro-icon/components';
import { getOrgChart, getProcessFlow, getRunbook } from '~/utils/lens-demo';

const org = getOrgChart();
const flow = getProcessFlow();
const runbook = getRunbook();

const tabs = [
  { id: 'org', label: 'Org chart' },
  { id: 'process', label: 'Process flow' },
  { id: 'runbook', label: 'Runbook' },
];
---

<div
  data-lens-demo
  class="bg-slate-900/90 rounded-2xl border-2 border-primary shadow-[0_0_48px_rgba(13,148,136,0.35)] overflow-hidden"
>
  <!-- Source banner: one document drives every view -->
  <div class="flex items-center gap-2 p-3 border-b border-white/8">
    <div
      class="w-6 h-6 rounded-lg bg-primary/25 border border-primary/40 flex items-center justify-center flex-shrink-0"
    >
      <Icon name="tabler:dna" class="w-3.5 h-3.5 text-primary" />
    </div>
    <span class="text-xs font-bold text-primary uppercase tracking-widest">One DNA</span>
    <span class="ml-auto text-xs text-slate-500 font-mono">lending.dna</span>
  </div>

  <!-- View tabs -->
  <div class="flex flex-wrap gap-1 px-3 pt-3" role="tablist" aria-label="View">
    {
      tabs.map((t, i) => (
        <button
          role="tab"
          data-lens-tab={t.id}
          aria-selected={i === 0 ? 'true' : 'false'}
          aria-controls={`lens-panel-${t.id}`}
          class="lens-tab px-3 py-1.5 rounded-lg text-xs font-semibold transition-colors duration-150"
        >
          {t.label}
        </button>
      ))
    }
  </div>

  <div class="p-4 sm:p-6 min-h-[15rem] flex flex-col justify-center">
    <!-- Org chart -->
    <div id="lens-panel-org" role="tabpanel" data-lens-panel="org">
      <p class="text-xs text-slate-500 mb-5 text-center">Who reports to whom</p>
      <div class="overflow-x-auto">
        <div class="min-w-[20rem] flex justify-center">
          {
            org.roots.map((root) => (
              <div class="oc-node">
                <div class="oc-box oc-box--lead">
                  <div class="oc-role">{root.name}</div>
                  {root.holders[0] && <div class="oc-person">{root.holders[0]}</div>}
                </div>
                {root.reports.length > 0 && (
                  <div class="oc-children">
                    {root.reports.map((r) => (
                      <div class="oc-child">
                        <div class="oc-box">
                          <div class="oc-role">{r.name}</div>
                          {r.holders[0] && <div class="oc-person">{r.holders[0]}</div>}
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Process flow -->
    <div id="lens-panel-process" role="tabpanel" data-lens-panel="process" hidden>
      <p class="text-xs text-slate-500 mb-5 text-center">How a loan moves through the team</p>
      <div class="overflow-x-auto">
        <div class="flex items-center gap-2 min-w-max pb-1 justify-center">
          {
            flow.steps.map((s, i, arr) => (
              <>
                <div class="flex flex-col items-center gap-1.5 w-[7.5rem]">
                  <div class="w-9 h-9 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center text-sm font-bold text-primary">
                    {i + 1}
                  </div>
                  <span class="text-sm text-slate-100 text-center leading-tight">{s.title}</span>
                  {s.actor && (
                    <span class="rounded bg-white/8 px-1.5 py-0.5 text-[11px] text-slate-400">{s.actor}</span>
                  )}
                </div>
                {i < arr.length - 1 && <Icon name="tabler:arrow-right" class="w-4 h-4 text-primary/60 flex-shrink-0" />}
              </>
            ))
          }
        </div>
      </div>
    </div>

    <!-- Runbook -->
    <div id="lens-panel-runbook" role="tabpanel" data-lens-panel="runbook" hidden>
      <p class="text-xs text-slate-500 mb-5 text-center">Step by step — who does each part</p>
      <div class="max-w-md mx-auto space-y-2.5">
        {
          runbook.items.map((item) => (
            <div class="flex gap-3 rounded-xl bg-slate-800/60 border border-white/10 px-4 py-3">
              <span class="w-6 h-6 mt-0.5 flex-shrink-0 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center text-xs font-bold text-primary">
                {item.n}
              </span>
              <div class="flex-1 min-w-0">
                <div class="flex items-center justify-between gap-2">
                  <span class="text-sm font-medium text-slate-100">{item.title}</span>
                  {item.owner && (
                    <span class="flex-shrink-0 rounded bg-white/8 px-2 py-0.5 text-[11px] text-slate-400">
                      {item.owner}
                    </span>
                  )}
                </div>
                {item.detail && <p class="mt-0.5 text-xs text-slate-400 leading-snug">{item.detail}</p>}
                {item.operation && <p class="mt-1 text-[10px] font-mono text-slate-500">{item.operation}</p>}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>

  <!-- Section CTA -->
  <div class="flex items-center justify-between gap-3 px-4 sm:px-6 py-3 border-t border-white/8">
    <span class="text-xs text-slate-500">Same document. Different lens.</span>
    <a
      href="/playground"
      class="inline-flex items-center gap-1.5 text-xs font-semibold text-primary hover:text-primary/80 transition-colors"
    >
      Build your own
      <Icon name="tabler:arrow-right" class="w-3.5 h-3.5" />
    </a>
  </div>
</div>

<style>
  .lens-tab {
    color: rgb(100 116 139);
    cursor: pointer;
    border: 1px solid transparent;
  }
  .lens-tab:hover {
    color: rgb(203 213 225);
    background: rgb(255 255 255 / 0.07);
    border-color: rgb(255 255 255 / 0.1);
  }
  .lens-tab[aria-selected='true'] {
    background: rgb(13 148 136 / 0.2);
    color: rgb(45 212 191);
    border-color: rgb(13 148 136 / 0.4);
  }

  /* Org-chart connectors — a vertical drop from the lead, a horizontal bar
     across the reports, and a vertical drop into each report box. */
  .oc-node {
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .oc-box {
    border-radius: 0.75rem;
    padding: 0.5rem 1rem;
    text-align: center;
    background: rgb(30 41 59 / 0.6);
    border: 1px solid rgb(255 255 255 / 0.1);
  }
  .oc-box--lead {
    background: rgb(30 41 59 / 0.8);
    border-color: rgb(13 148 136 / 0.4);
    box-shadow: 0 0 16px rgb(13 148 136 / 0.15);
  }
  .oc-role {
    font-size: 0.875rem;
    font-weight: 600;
    color: rgb(241 245 249);
    line-height: 1.2;
  }
  .oc-person {
    font-size: 0.75rem;
    color: rgb(148 163 184);
  }
  .oc-children {
    display: flex;
    justify-content: center;
    position: relative;
    margin-top: 1.25rem;
  }
  /* vertical drop from the lead box down to the horizontal bar */
  .oc-children::before {
    content: '';
    position: absolute;
    top: -1.25rem;
    left: 50%;
    height: 1.25rem;
    border-left: 1px solid rgb(13 148 136 / 0.4);
  }
  .oc-child {
    position: relative;
    padding: 1.25rem 0.5rem 0;
  }
  /* horizontal bar segment (tiles across adjacent children) */
  .oc-child::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    border-top: 1px solid rgb(13 148 136 / 0.4);
  }
  /* vertical drop into each report box */
  .oc-child::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    height: 1.25rem;
    border-left: 1px solid rgb(13 148 136 / 0.4);
  }
  .oc-child:first-child::after {
    left: 50%;
    width: 50%;
  }
  .oc-child:last-child::after {
    width: 50%;
  }
  .oc-child:only-child::after {
    display: none;
  }
</style>

<script>
  document.querySelectorAll<HTMLElement>('[data-lens-demo]').forEach((demo) => {
    const tabs = Array.from(demo.querySelectorAll<HTMLButtonElement>('[data-lens-tab]'));
    const ids = tabs.map((t) => t.dataset.lensTab!);

    const select = (id: string) => {
      tabs.forEach((t) => t.setAttribute('aria-selected', String(t.dataset.lensTab === id)));
      demo.querySelectorAll<HTMLElement>('[data-lens-panel]').forEach((p) => {
        p.hidden = p.dataset.lensPanel !== id;
      });
    };

    let cycling = false;
    let timer: ReturnType<typeof setInterval> | undefined;
    const stop = () => {
      cycling = false;
      if (timer) clearInterval(timer);
    };

    // Any interaction ends the auto-cycle for the session.
    tabs.forEach((tab) =>
      tab.addEventListener('click', () => {
        stop();
        select(tab.dataset.lensTab!);
      })
    );

    // Idle auto-cycle — 10s per view. Off under reduced-motion; only while on screen.
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)');
    const startCycle = () => {
      if (cycling || reduce.matches || ids.length < 2) return;
      cycling = true;
      let i = ids.indexOf(tabs.find((t) => t.getAttribute('aria-selected') === 'true')?.dataset.lensTab ?? ids[0]);
      timer = setInterval(() => {
        if (!cycling) return;
        i = (i + 1) % ids.length;
        select(ids[i]);
      }, 10000);
    };

    const io = new IntersectionObserver(
      (entries) => {
        for (const e of entries) {
          if (e.isIntersecting) startCycle();
          else if (cycling) {
            if (timer) clearInterval(timer);
            cycling = false;
          }
        }
      },
      { threshold: 0.3 }
    );
    io.observe(demo);
  });
</script>
