---
import { Icon } from 'astro-icon/components';

const sources = [
  { name: 'Google Drive', icon: 'logos:google-drive' },
  { name: 'Notion', icon: 'ri:notion-fill' },
  { name: 'Confluence', icon: 'logos:confluence' },
  { name: 'Slack', icon: 'logos:slack' },
  { name: 'PDF / Docs', icon: 'tabler:pdf' },
  { name: 'Websites', icon: 'tabler:globe' },
];

const vendors = [
  { name: 'Notion', icon: 'ri:notion-fill' },
  { name: 'Confluence', icon: 'logos:confluence' },
  { name: 'Google Drive', icon: 'logos:google-drive' },
  { name: 'Slack', icon: 'logos:slack' },
  { name: 'Linear', icon: 'simple-icons:linear' },
  { name: 'Jira', icon: 'logos:jira' },
];
---

<section id="operations-b" class="py-20 scroll-mt-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-12 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <h2
        class="inline-flex items-center px-5 py-2 rounded-full border-2 border-primary bg-primary/10 text-sm font-semibold text-primary uppercase tracking-[0.2em] mb-4"
      >
        Operations Layer
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto leading-relaxed">
        Structure how your business runs — from meeting notes and process docs to executable flows your whole team can
        follow.
      </p>
    </div>

    <!-- Hub-and-spoke grid -->
    <div
      class="grid grid-cols-1 lg:grid-cols-[1fr_280px_1fr] gap-6 items-center intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
    >
      <!-- Left: Sources -->
      <div class="flex flex-col gap-2">
        <p class="text-[9px] font-bold uppercase tracking-widest text-slate-500 mb-1 text-right lg:text-right">
          Sources
        </p>
        {
          sources.map(({ name, icon }) => (
            <div class="flex items-center justify-end gap-2 group">
              <span class="text-[10px] text-slate-400 group-hover:text-slate-200 transition-colors">{name}</span>
              <div class="flex items-center gap-1.5">
                <div class="w-7 h-7 rounded-lg bg-slate-800/80 border border-white/10 flex items-center justify-center flex-shrink-0">
                  <Icon name={icon} class="w-3.5 h-3.5 text-slate-400" />
                </div>
                <div class="hidden lg:block w-6 h-px bg-gradient-to-r from-white/20 to-primary/40" />
              </div>
            </div>
          ))
        }
      </div>

      <!-- Center: DNA Core -->
      <div
        class="bg-slate-900/90 rounded-2xl border border-primary/60 p-5 shadow-[0_0_40px_rgba(13,148,136,0.25)] relative"
      >
        <!-- Top connector dots (mobile) -->
        <div class="lg:hidden flex justify-center mb-3">
          <Icon name="tabler:arrow-down" class="w-4 h-4 text-primary/50 rotate-180" />
        </div>

        <div class="flex items-center gap-2 mb-4">
          <div class="w-6 h-6 rounded-lg bg-primary/25 border border-primary/40 flex items-center justify-center">
            <Icon name="tabler:dna" class="w-3.5 h-3.5 text-primary" />
          </div>
          <span class="text-[10px] font-bold text-primary uppercase tracking-widest">DNA Spec</span>
          <span class="ml-auto text-[10px] text-slate-400 font-mono">operations.dna</span>
        </div>

        <div class="font-mono text-[11px] leading-loose">
          <div>
            <span class="text-violet-400">process</span><span class="text-slate-500">:</span>
            <span class="text-amber-300">CustomerOnboarding</span>
          </div>
          <div class="ml-2 text-slate-400">
            owner<span class="text-slate-600">:</span>
            <span class="text-sky-400">SuccessTeam</span>
          </div>
          <div class="ml-2 text-slate-400">steps<span class="text-slate-600">:</span></div>
          <div class="ml-4">
            <span class="text-slate-500">-</span>
            <span class="text-violet-400">welcome-email</span>
          </div>
          <div class="ml-4">
            <span class="text-slate-500">-</span>
            <span class="text-violet-400">account-setup</span>
          </div>
          <div class="ml-4"><span class="text-slate-500">-</span> <span class="text-violet-400">intro-call</span></div>
          <div class="ml-4">
            <span class="text-slate-500">-</span>
            <span class="text-violet-400">30-day-check-in</span>
          </div>
          <div class="mt-1 ml-2 text-slate-400">triggers<span class="text-slate-600">:</span></div>
          <div class="ml-4"><span class="text-slate-500">-</span> <span class="text-amber-300">new-signup</span></div>
          <div class="ml-4"><span class="text-slate-500">-</span> <span class="text-amber-300">plan-upgrade</span></div>
          <div class="mt-1 ml-2 text-slate-400">
            sla<span class="text-slate-600">:</span>
            <span class="text-emerald-400">24h response</span>
          </div>
        </div>

        <!-- Bottom connector (mobile) -->
        <div class="lg:hidden flex justify-center mt-3">
          <Icon name="tabler:arrow-down" class="w-4 h-4 text-primary/50" />
        </div>
      </div>

      <!-- Right: Outputs -->
      <div class="flex flex-col gap-3">
        <p class="text-[9px] font-bold uppercase tracking-widest text-slate-500 mb-1">Outputs</p>

        <!-- Process Flow -->
        <div class="flex items-start gap-2">
          <div class="hidden lg:block w-6 h-px bg-gradient-to-l from-white/20 to-primary/40 mt-3 flex-shrink-0"></div>
          <div class="flex-1 bg-slate-800/80 rounded-xl border border-white/10 p-3">
            <span
              class="text-[8px] font-bold uppercase tracking-widest text-violet-300 bg-violet-500/20 border border-violet-500/30 rounded-full px-2 py-0.5"
            >
              Process Flow
            </span>
            <div class="mt-2 space-y-0">
              {
                ['Welcome email', 'Account setup', 'Intro call'].map((step, i) => (
                  <div class="flex gap-2">
                    <div class="flex flex-col items-center flex-shrink-0">
                      <div class="w-4 h-4 rounded-full bg-primary/20 border border-primary/40 flex items-center justify-center">
                        <span class="text-[7px] font-bold text-primary">{i + 1}</span>
                      </div>
                      {i < 2 && <div class="w-px flex-1 min-h-[10px] bg-white/10 my-0.5" />}
                    </div>
                    <p class="text-[9px] text-slate-300 pb-1.5">{step}</p>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <!-- SOP Document -->
        <div class="flex items-start gap-2">
          <div class="hidden lg:block w-6 h-px bg-gradient-to-l from-white/20 to-primary/40 mt-3 flex-shrink-0"></div>
          <div class="flex-1 bg-slate-800/80 rounded-xl border border-white/10 p-3">
            <span
              class="text-[8px] font-bold uppercase tracking-widest text-sky-300 bg-sky-500/20 border border-sky-500/30 rounded-full px-2 py-0.5"
            >
              SOP Document
            </span>
            <div class="mt-2 space-y-1.5">
              <div class="h-2 w-3/4 bg-slate-600/60 rounded-sm"></div>
              <div class="h-1.5 w-full bg-slate-700/60 rounded-sm"></div>
              <div class="h-1.5 w-5/6 bg-slate-700/60 rounded-sm"></div>
              <div class="h-1.5 w-4/6 bg-slate-700/60 rounded-sm"></div>
              <div
                class="mt-2 inline-flex items-center gap-1 bg-slate-700/60 border border-white/10 rounded px-2 py-0.5"
              >
                <Icon name="tabler:download" class="w-2.5 h-2.5 text-slate-400" />
                <span class="text-[8px] text-slate-400">Download PDF</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Diagram -->
        <div class="flex items-start gap-2">
          <div class="hidden lg:block w-6 h-px bg-gradient-to-l from-white/20 to-primary/40 mt-3 flex-shrink-0"></div>
          <div class="flex-1 bg-slate-800/80 rounded-xl border border-white/10 p-3">
            <span
              class="text-[8px] font-bold uppercase tracking-widest text-amber-300 bg-amber-500/20 border border-amber-500/30 rounded-full px-2 py-0.5"
            >
              Diagram
            </span>
            <div class="mt-2 flex items-center gap-1.5">
              <div
                class="bg-slate-700/60 border border-white/10 rounded px-2 py-1 text-[8px] text-slate-300 whitespace-nowrap"
              >
                Start
              </div>
              <div class="flex-1 h-px bg-white/20 relative">
                <div
                  class="absolute right-0 top-1/2 -translate-y-1/2 border-t border-r border-white/30 w-1.5 h-1.5 rotate-45 translate-x-0.5"
                >
                </div>
              </div>
              <div
                class="bg-primary/20 border border-primary/40 rounded px-2 py-1 text-[8px] text-primary whitespace-nowrap"
              >
                Onboard
              </div>
              <div class="flex-1 h-px bg-white/20 relative">
                <div
                  class="absolute right-0 top-1/2 -translate-y-1/2 border-t border-r border-white/30 w-1.5 h-1.5 rotate-45 translate-x-0.5"
                >
                </div>
              </div>
              <div
                class="bg-emerald-500/20 border border-emerald-500/40 rounded px-2 py-1 text-[8px] text-emerald-400 whitespace-nowrap"
              >
                Done
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Vendor Sync Strip -->
    <div
      class="mt-8 pt-6 border-t border-white/10 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
    >
      <div class="flex flex-wrap items-center gap-3 justify-center">
        <span class="text-[9px] font-bold uppercase tracking-widest text-slate-500 mr-2">Synced to</span>
        {
          vendors.map(({ name, icon }) => (
            <div class="flex items-center gap-1.5 bg-slate-800/60 border border-white/10 rounded-full px-3 py-1.5">
              <span class="sync-dot w-1.5 h-1.5 rounded-full bg-emerald-400 flex-shrink-0" />
              <Icon name={icon} class="w-3 h-3 text-slate-400" />
              <span class="text-[9px] text-slate-300">{name}</span>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .sync-dot {
    animation: pulse-dot 2s ease-in-out infinite;
  }
  @keyframes pulse-dot {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.25;
    }
  }
</style>
