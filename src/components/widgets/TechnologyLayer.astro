---
import { Icon } from 'astro-icon/components';

const endpoints = [
  { method: 'GET', path: '/customers', returnType: 'Customer[]', methodCls: 'text-emerald-400' },
  { method: 'POST', path: '/customers', returnType: 'Customer', methodCls: 'text-sky-400' },
  { method: 'GET', path: '/customers/:id', returnType: 'Customer', methodCls: 'text-emerald-400' },
  { method: 'PATCH', path: '/customers/:id', returnType: 'Customer', methodCls: 'text-amber-400' },
  { method: 'DELETE', path: '/customers/:id', returnType: '204', methodCls: 'text-red-400' },
];
---

<section class="py-20">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <!-- Header -->
    <div class="text-center mb-12 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade">
      <h2
        class="inline-flex items-center px-5 py-2 rounded-full border-2 border-primary bg-primary/10 text-sm font-semibold text-primary uppercase tracking-[0.2em] mb-4"
      >
        Technology Layer
      </h2>
      <p class="text-slate-400 max-w-xl mx-auto leading-relaxed">
        From product spec to running architecture — generating API contracts, data schemas, and the services that ship.
      </p>
    </div>

    <!-- Three-panel flow: system.dna → API Contract → Architecture Map -->
    <div
      class="grid lg:grid-cols-[1fr_36px_1.5fr_36px_1.5fr] items-stretch gap-y-4 intersect-once motion-safe:md:opacity-0 motion-safe:md:intersect:animate-fade"
    >
      <!-- Panel 1: system.dna spec -->
      <div class="bg-slate-900/90 rounded-2xl border border-sky-500/55 p-5">
        <div class="flex items-center gap-2 mb-4">
          <div class="w-6 h-6 rounded-lg bg-sky-500/25 border border-sky-500/35 flex items-center justify-center">
            <Icon name="tabler:cpu" class="w-3.5 h-3.5 text-sky-400" />
          </div>
          <span class="text-[10px] font-bold text-sky-400 uppercase tracking-widest">DNA Spec</span>
          <span class="ml-auto text-[10px] text-slate-400 font-mono">system.dna</span>
        </div>
        <div class="font-mono text-[11px] leading-loose">
          <div>
            <span class="text-violet-400">service</span><span class="text-slate-500">:</span>
            <span class="text-amber-300">CustomerAPI</span>
          </div>
          <div class="ml-2 text-slate-400">
            runtime<span class="text-slate-600">:</span>
            <span class="text-sky-400">Node.js 20</span>
          </div>
          <div class="ml-2 text-slate-400">endpoints<span class="text-slate-600">:</span></div>
          <div class="ml-4">
            <span class="text-slate-500">-</span>
            <span class="text-emerald-400">GET</span>
            <span class="text-slate-300">/customers</span>
          </div>
          <div class="ml-4">
            <span class="text-slate-500">-</span>
            <span class="text-sky-400">POST</span>
            <span class="text-slate-300">/customers</span>
          </div>
          <div class="ml-4">
            <span class="text-slate-500">-</span>
            <span class="text-emerald-400">GET</span>
            <span class="text-slate-300">/customers/:id</span>
          </div>
          <div class="mt-1 ml-2 text-slate-400">database<span class="text-slate-600">:</span></div>
          <div class="ml-4 text-slate-400">
            engine<span class="text-slate-600">:</span>
            <span class="text-sky-400">PostgreSQL</span>
          </div>
          <div class="ml-4 text-slate-400">
            tables<span class="text-slate-600">:</span>
            <span class="text-amber-300">[customers, orders]</span>
          </div>
          <div class="mt-1 ml-2 text-slate-400">depends_on<span class="text-slate-600">:</span></div>
          <div class="ml-4">
            <span class="text-slate-500">-</span>
            <span class="text-violet-400">AuthService</span>
          </div>
          <div class="ml-4">
            <span class="text-slate-500">-</span>
            <span class="text-violet-400">EmailService</span>
          </div>
        </div>
      </div>

      <!-- Arrow 1 -->
      <div class="hidden lg:flex items-center justify-center">
        <Icon name="tabler:arrow-right" class="w-5 h-5 text-primary/50" />
      </div>

      <!-- Panel 2: Generated API Contract -->
      <div class="bg-slate-800/80 rounded-2xl border border-white/20 p-4">
        <div class="flex items-center justify-between mb-4">
          <span
            class="text-[9px] font-bold uppercase tracking-widest bg-sky-500/25 text-sky-300 border border-sky-500/40 rounded-full px-2.5 py-1"
          >
            API Contract
          </span>
          <div class="flex items-center gap-1.5">
            <Icon name="tabler:file-code" class="w-3 h-3 text-slate-500" />
            <span class="text-[9px] text-slate-400 font-mono">v2.1.0</span>
          </div>
        </div>

        <div class="text-[10px] font-semibold text-slate-300 mb-2.5">CustomerAPI</div>

        <div class="space-y-1">
          {
            endpoints.map(({ method, path, returnType, methodCls }) => (
              <div class="flex items-center gap-2 py-1 px-2 rounded border border-white/10 bg-white/[0.04]">
                <span class:list={['font-mono font-bold text-[9px] w-10 flex-shrink-0', methodCls]}>{method}</span>
                <span class="font-mono text-[10px] text-slate-200 flex-1">{path}</span>
                <span class="text-[9px] text-slate-400 flex-shrink-0">{returnType}</span>
              </div>
            ))
          }
        </div>

        <div class="mt-3 pt-3 border-t border-white/8 space-y-1">
          <div class="flex items-center gap-2 text-[9px] text-slate-400">
            <span class="text-slate-300">Body:</span>
            <span class="font-mono">{'{ name, status, plan }'}</span>
          </div>
          <div class="flex items-center gap-2 text-[9px] text-slate-400">
            <span class="text-slate-300">Auth:</span>
            <span class="font-mono">Bearer required</span>
          </div>
          <span class="mt-1 block text-[8px] text-sky-400/60 italic">Generated from system.dna</span>
        </div>
      </div>

      <!-- Arrow 2 -->
      <div class="hidden lg:flex items-center justify-center">
        <Icon name="tabler:arrow-right" class="w-5 h-5 text-primary/50" />
      </div>

      <!-- Panel 3: Architecture Map -->
      <div class="bg-slate-800/80 rounded-2xl border border-white/20 p-4 flex flex-col">
        <div class="flex items-center justify-between mb-4">
          <span
            class="text-[9px] font-bold uppercase tracking-widest bg-violet-500/25 text-violet-300 border border-violet-500/40 rounded-full px-2.5 py-1"
          >
            Architecture
          </span>
          <div class="flex items-center gap-1.5">
            <Icon name="tabler:hierarchy" class="w-3 h-3 text-slate-500" />
            <span class="text-[9px] text-slate-400 font-mono">service map</span>
          </div>
        </div>

        <!-- Service dependency tree -->
        <div class="space-y-2 flex-1">
          <!-- Primary service -->
          <div class="rounded-lg border border-sky-500/40 bg-sky-500/10 px-3 py-2 flex items-center gap-2">
            <div class="w-1.5 h-1.5 rounded-full bg-sky-400 flex-shrink-0"></div>
            <span class="text-[10px] font-semibold text-sky-300">CustomerAPI</span>
            <span class="ml-auto text-[8px] text-slate-400 bg-white/8 rounded px-1.5 py-0.5">primary</span>
          </div>

          <!-- Dependencies (indented tree) -->
          <div class="ml-4 pl-3 border-l border-white/15 space-y-1.5">
            <div class="rounded-md border border-white/12 bg-white/[0.05] px-2.5 py-1.5 flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-primary/80 flex-shrink-0"></div>
              <span class="text-[10px] text-slate-300">AuthService</span>
              <span class="ml-auto text-[8px] text-slate-500">dependency</span>
            </div>

            <div class="rounded-md border border-white/12 bg-white/[0.05] px-2.5 py-1.5 flex items-center gap-2">
              <div class="w-1.5 h-1.5 rounded-full bg-primary/80 flex-shrink-0"></div>
              <span class="text-[10px] text-slate-300">EmailService</span>
              <span class="ml-auto text-[8px] text-slate-500">dependency</span>
            </div>

            <div class="rounded-md border border-white/12 bg-white/[0.05] px-2.5 py-2">
              <div class="flex items-center gap-2 mb-1.5">
                <div class="w-1.5 h-1.5 rounded-full bg-amber-400/80 flex-shrink-0"></div>
                <span class="text-[10px] text-slate-300">PostgreSQL</span>
                <span class="ml-auto text-[8px] text-slate-500">database</span>
              </div>
              <div class="ml-3.5 pl-2 border-l border-white/12 flex gap-2">
                <span class="text-[9px] text-slate-400 font-mono bg-white/6 rounded px-1.5 py-0.5">customers</span>
                <span class="text-[9px] text-slate-400 font-mono bg-white/6 rounded px-1.5 py-0.5">orders</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Footer label -->
        <div class="mt-3 pt-3 border-t border-white/8 flex items-center gap-1.5">
          <Icon name="tabler:cpu" class="w-2.5 h-2.5 text-sky-400/60" />
          <span class="text-[8px] text-slate-500"
            >Generated from <span class="text-sky-400/70 font-mono">CustomerAPI</span> DNA spec</span
          >
        </div>
      </div>
    </div>
  </div>
</section>
