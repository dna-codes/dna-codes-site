---
interface Props {
  orientation?: 'vertical' | 'horizontal';
  nodeSize?: number;
  helixWidth?: number;
  filled?: boolean;
  speed?: number;
  class?: string;
  style?: string;
}

const { orientation = 'vertical', nodeSize, helixWidth, filled = false, speed, class: className, style } = Astro.props;
---

<div
  data-dna-helix
  data-orientation={orientation}
  {...nodeSize !== undefined ? { 'data-node-size': String(nodeSize) } : {}}
  {...helixWidth !== undefined ? { 'data-helix-width': String(helixWidth) } : {}}
  {...filled ? { 'data-filled': '' } : {}}
  {...speed !== undefined ? { 'data-speed': String(speed) } : {}}
  class:list={['w-full h-full overflow-hidden pointer-events-none', className]}
  style={style}
  aria-hidden="true"
>
</div>

<script is:inline>
  (function () {
    // Store the init function once; re-use on subsequent DnaHelix instances.
    if (!window.__initDnaHelix) {
      window.__initDnaHelix = function (el, opts) {
        const isVertical = (opts.orientation || 'vertical') === 'vertical';
        const BASE_R = opts.nodeSize != null ? opts.nodeSize : 6.5;
        const AMP_OVERRIDE = opts.helixWidth != null ? opts.helixWidth : null;
        const RUNGS_PER_TURN = 10,
          DEPTH_SCALE = 0.5,
          SPEED = opts.speed != null ? opts.speed : 0.03,
          MAX_ALPHA = 0.55;
        const CR = 45,
          CG = 212,
          CB = 191;
        const BG = 'rgb(10,15,30)';

        function rgba(a) {
          return 'rgba(' + CR + ',' + CG + ',' + CB + ',' + a.toFixed(3) + ')';
        }

        const canvas = document.createElement('canvas');
        canvas.style.cssText = 'position:absolute;inset:0;width:100%;height:100%;pointer-events:none;display:block;';
        el.style.position = 'relative';
        el.insertBefore(canvas, el.firstChild);

        const ctx = canvas.getContext('2d');
        let W = 0,
          H = 0,
          dpr = 1,
          raf = 0;

        function resize() {
          dpr = Math.min(window.devicePixelRatio || 1, 2);
          const r = el.getBoundingClientRect();
          W = r.width || window.innerWidth;
          H = r.height || window.innerHeight;
          canvas.width = Math.round(W * dpr);
          canvas.height = Math.round(H * dpr);
        }

        if (typeof ResizeObserver !== 'undefined') new ResizeObserver(resize).observe(el);
        resize();

        function frame(ts) {
          if (document.hidden) {
            raf = 0;
            return;
          }
          ctx.clearRect(0, 0, canvas.width, canvas.height);
          ctx.save();
          ctx.scale(dpr, dpr);

          const angle = ts * 0.001 * SPEED * 2 * Math.PI;
          const pitch = (2 * Math.PI) / RUNGS_PER_TURN;
          const mainLen = isVertical ? H : W;
          const oscLen = isVertical ? W : H;
          const pad = mainLen * (isVertical ? 0.05 : 0.02);
          const N_RUNGS = Math.max(RUNGS_PER_TURN, Math.round((mainLen - pad * 2) / 80) + 1);
          const spacing = (mainLen - pad * 2) / (N_RUNGS - 1);
          const center = oscLen / 2;
          const crossLen = isVertical ? W : H;
          const amp =
            AMP_OVERRIDE != null
              ? Math.min(AMP_OVERRIDE, crossLen * 0.32)
              : isVertical
                ? Math.min(W * 0.13, 68)
                : Math.min(H * 0.22, 80);
          const nodeR = Math.min(BASE_R, crossLen * 0.055);
          const circles = [];

          for (let i = 0; i < N_RUNGS; i++) {
            const theta = angle + i * pitch;
            const cosT = Math.cos(theta);
            const sinT = Math.sin(theta);
            const main = pad + i * spacing;
            const oscA = center + amp * cosT;
            const oscB = center - amp * cosT;
            const x1 = isVertical ? oscA : main;
            const y1 = isVertical ? main : oscA;
            const x2 = isVertical ? oscB : main;
            const y2 = isVertical ? main : oscB;

            const lineA = MAX_ALPHA * (0.4 + 0.6 * Math.abs(cosT));
            ctx.beginPath();
            ctx.moveTo(x1, y1);
            ctx.lineTo(x2, y2);
            ctx.strokeStyle = rgba(lineA);
            ctx.lineWidth = 1.5;
            ctx.stroke();

            circles.push({ x: x1, y: y1, r: nodeR * (1 + DEPTH_SCALE * sinT), z: sinT });
            circles.push({ x: x2, y: y2, r: nodeR * (1 + DEPTH_SCALE * -sinT), z: -sinT });
          }

          circles.sort(function (a, b) {
            return a.z - b.z;
          });
          for (let j = 0; j < circles.length; j++) {
            const c = circles[j];
            const sA = MAX_ALPHA * (0.35 + 0.65 * (c.z + 1) * 0.5);
            const t = 0.35 + 0.65 * Math.pow((c.z + 1) / 2, 2);
            const bgR = 10,
              bgG = 15,
              bgB = 30;
            const fR = Math.round(bgR + (CR - bgR) * t);
            const fG = Math.round(bgG + (CG - bgG) * t);
            const fB = Math.round(bgB + (CB - bgB) * t);
            ctx.beginPath();
            ctx.arc(c.x, c.y, Math.max(c.r, 0.5), 0, 6.283185);
            ctx.fillStyle = 'rgb(' + fR + ',' + fG + ',' + fB + ')';
            ctx.strokeStyle = rgba(sA);
            ctx.lineWidth = 1.5;
            ctx.fill();
            ctx.stroke();
          }

          ctx.restore();
          raf = requestAnimationFrame(frame);
        }

        function start() {
          if (!raf) raf = requestAnimationFrame(frame);
        }
        document.addEventListener('visibilitychange', function () {
          if (!document.hidden) start();
        });
        start();
      };
    }

    // Init any uninitialized instances already in the DOM.
    document.querySelectorAll('[data-dna-helix]:not([data-helix-ready])').forEach(function (el) {
      el.dataset.helixReady = '1';
      window.__initDnaHelix(el, {
        orientation: el.dataset.orientation,
        nodeSize: el.dataset.nodeSize ? parseFloat(el.dataset.nodeSize) : undefined,
        helixWidth: el.dataset.helixWidth ? parseFloat(el.dataset.helixWidth) : undefined,
        filled: 'filled' in el.dataset,
        speed: el.dataset.speed ? parseFloat(el.dataset.speed) : undefined,
      });
    });
  })();
</script>
