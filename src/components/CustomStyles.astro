---
import '@fontsource-variable/inter';
---

<style is:inline>
  :root {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(13 148 136);
    --aw-color-secondary: rgb(15 118 110);
    --aw-color-accent: rgb(45 212 191);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(10 15 30);

    --aw-color-bg-page-dark: rgb(10 15 30);

    ::selection {
      background-color: rgb(13 148 136 / 40%);
    }
  }

  .dark {
    --aw-font-sans: 'Inter Variable';
    --aw-font-serif: 'Inter Variable';
    --aw-font-heading: 'Inter Variable';

    --aw-color-primary: rgb(13 148 136);
    --aw-color-secondary: rgb(15 118 110);
    --aw-color-accent: rgb(45 212 191);

    --aw-color-text-heading: rgb(247 248 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(10 15 30);

    ::selection {
      background-color: rgb(13 148 136 / 40%);
    }
  }
</style>
