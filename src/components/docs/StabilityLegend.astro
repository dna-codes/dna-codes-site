---
import StabilityPill from '~/components/docs/StabilityPill.astro';
import { STABILITY_ORDER } from '~/utils/schema-doc';

const DESCRIPTIONS: Record<(typeof STABILITY_ORDER)[number], string> = {
  experimental: 'shape may change without notice',
  beta: 'stabilizing; minor changes possible',
  stable: 'safe to build on; changes follow semver',
};
---

<div
  class="not-prose my-6 flex flex-wrap items-center gap-x-4 gap-y-2 rounded-lg border border-gray-200 bg-gray-50 px-4 py-3 text-sm dark:border-slate-700 dark:bg-slate-800/50"
>
  <span class="font-semibold text-gray-700 dark:text-slate-300">Stability:</span>
  {
    STABILITY_ORDER.map((level) => (
      <span class="inline-flex items-center gap-1.5 text-gray-600 dark:text-slate-400">
        <StabilityPill level={level} />
        {DESCRIPTIONS[level]}
      </span>
    ))
  }
</div>
