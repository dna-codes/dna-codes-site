---
import { parseSentence, lensNodes, lensEdges, isLayerLens, lensAnchor, type LensDoc } from '~/utils/lens-doc';

export interface Props {
  lens: LensDoc;
}

const { lens } = Astro.props;

const id = lensAnchor(lens);
const nodes = lensNodes(lens);
const edges = lensEdges(lens);
const layer = isLayerLens(lens);
const sentence = parseSentence(lens.sentence);
---

<section id={id} class="scroll-mt-24">
  <h3 class="flex flex-wrap items-center gap-x-3 gap-y-1">
    <a href={`#${id}`} class="no-underline hover:underline">{lens.name}</a>
    <span
      class="not-prose rounded-full px-2 py-0.5 text-xs font-medium text-gray-600 ring-1 ring-gray-200 dark:text-slate-400 dark:ring-slate-700"
    >
      {layer ? 'layer lens' : 'subgraph lens'}
    </span>
  </h3>

  {
    sentence.length > 0 && (
      <p class="not-prose my-4 text-lg leading-relaxed text-gray-700 dark:text-slate-300">
        {sentence.map((part) =>
          part.kind === 'slot' ? (
            <span class="rounded bg-primary/10 px-1.5 py-0.5 font-mono text-sm font-medium text-primary">
              {part.value}
            </span>
          ) : (
            <span>{part.value}</span>
          )
        )}
      </p>
    )
  }

  {
    layer ? (
      <>
        <h4 class="mt-6 mb-2 text-sm font-semibold uppercase tracking-wide text-gray-600 dark:text-slate-400">
          Resource types
        </h4>
        <ul class="not-prose flex flex-wrap gap-2">
          {nodes.map((n) => (
            <li class="rounded-md bg-gray-100 px-2.5 py-1 font-mono text-xs text-gray-800 dark:bg-slate-800 dark:text-slate-200">
              {n.type}
            </li>
          ))}
        </ul>
      </>
    ) : (
      <>
        <h4 class="mt-6 mb-2 text-sm font-semibold uppercase tracking-wide text-gray-600 dark:text-slate-400">
          Node slots
        </h4>
        <div class="not-prose my-4 overflow-x-auto rounded-lg border border-gray-200 dark:border-slate-700">
          <table class="min-w-full divide-y divide-gray-200 text-sm dark:divide-slate-700">
            <thead class="bg-gray-50 dark:bg-slate-800">
              <tr>
                <th class="px-4 py-2 text-left font-semibold text-gray-900 dark:text-white">Slot</th>
                <th class="px-4 py-2 text-left font-semibold text-gray-900 dark:text-white">Resource type</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-slate-800">
              {nodes.map((n) => (
                <tr class="align-top">
                  <td class="px-4 py-2 font-mono text-xs text-gray-900 dark:text-white">{n.slot ?? '—'}</td>
                  <td class="px-4 py-2 font-mono text-xs text-gray-600 dark:text-slate-400">{n.type}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <h4 class="mt-6 mb-2 text-sm font-semibold uppercase tracking-wide text-gray-600 dark:text-slate-400">Edges</h4>
        <div class="not-prose my-4 overflow-x-auto rounded-lg border border-gray-200 dark:border-slate-700">
          <table class="min-w-full divide-y divide-gray-200 text-sm dark:divide-slate-700">
            <thead class="bg-gray-50 dark:bg-slate-800">
              <tr>
                <th class="px-4 py-2 text-left font-semibold text-gray-900 dark:text-white">From</th>
                <th class="px-4 py-2 text-left font-semibold text-gray-900 dark:text-white">To</th>
                <th class="px-4 py-2 text-left font-semibold text-gray-900 dark:text-white">Via (relationship)</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100 dark:divide-slate-800">
              {edges.map((e) => (
                <tr class="align-top">
                  <td class="px-4 py-2 font-mono text-xs text-gray-900 dark:text-white">{e.from}</td>
                  <td class="px-4 py-2 font-mono text-xs text-gray-900 dark:text-white">{e.to}</td>
                  <td class="px-4 py-2 font-mono text-xs text-gray-600 dark:text-slate-400">{e.via}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </>
    )
  }
</section>
