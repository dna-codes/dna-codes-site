{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "npm run check",
            "if": "Bash(git commit*)",
            "timeout": 120,
            "statusMessage": "Running npm run check before commit..."
          }
        ]
      }
    ]
  }
}
