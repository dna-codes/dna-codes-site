{
  "extends": "astro/tsconfigs/base",
  "compilerOptions": {
    "strictNullChecks": true,
    "allowJs": true,
    "baseUrl": ".",
    "paths": {
      "~/*": ["src/*"],
      "~schemas/*": ["node_modules/@dna-codes/dna-schemas/*"],
      "~lenses/*": ["node_modules/@dna-codes/dna-core/lenses/*"]
    }
  },
  "include": [".astro/types.d.ts", "**/*"],
  "exclude": ["dist/"]
}
